default_platform(:ios)

platform :ios do
  desc "Upload pre-built IPA to TestFlight"
  lane :upload_testflight do |options|
    ipa_path = options[:ipa_path] || "build/export/MagRabbit.ipa"
    api_key_path = File.expand_path(options[:api_key_path] || "~/.appstoreconnect/private_keys/AuthKey_#{ENV['API_KEY_ID']}.p8")

    # Load API key from .p8 file
    api_key = app_store_connect_api_key(
      key_id: ENV['API_KEY_ID'],
      issuer_id: ENV['API_ISSUER_ID'],
      key_filepath: api_key_path,
      is_key_content_base64: false,
      in_house: false
    )

    # Upload to TestFlight using the loaded API key
    pilot(
      ipa: ipa_path,
      api_key: api_key,
      app_identifier: "com.magrabbit.MagRabbit",
      apple_id: "6770562560",
      skip_waiting_for_build_processing: false,
      skip_submission: false,
      distribute_external: false
    )
  end

  desc "Submit an uploaded build to App Review"
  lane :submit_app_review do |options|
    build_number = options[:build_number] || ENV["GITHUB_RUN_NUMBER"]
    api_key_path = File.expand_path(options[:api_key_path] || "~/.appstoreconnect/private_keys/AuthKey_#{ENV['API_KEY_ID']}.p8")

    api_key = app_store_connect_api_key(
      key_id: ENV['API_KEY_ID'],
      issuer_id: ENV['API_ISSUER_ID'],
      key_filepath: api_key_path,
      is_key_content_base64: false,
      in_house: false
    )

    deliver(
      api_key: api_key,
      app_identifier: "com.magrabbit.MagRabbit",
      app_version: "1.0",
      build_number: build_number,
      name: "海外のマニアックな雑誌紹介",
      subtitle: "世界の小さな雑誌を探す",
      description: "海外のニッチな雑誌を日本語の紹介文で探せるアプリです。動物、食文化、DIY、テック、自然、都市観察、ZINE、音楽、建築など、少し変わったテーマの雑誌を集めました。\n\n本文を翻訳するアプリではありません。各雑誌の雰囲気やテーマを日本語で短く紹介し、気になったものは公式サイト検索から確認できます。\n\n国、ジャンル、入手メモ、出版社メモを見ながら、ふだん出会わない海外誌をゆっくり探せます。",
      keywords: "雑誌,海外雑誌,ZINE,ニッチ,マガジン,読書,カルチャー,趣味,出版",
      support_url: "https://github.com/snarfnet/MagRabbit/issues",
      privacy_url: "https://raw.githubusercontent.com/snarfnet/MagRabbit/codex/magazine-ui-redesign/PRIVACY.md",
      copyright: "2026 MagRabbit",
      primary_category: "Lifestyle",
      price_tier: 0,
      app_rating_config_path: "fastlane/metadata/app_rating_config.json",
      submit_for_review: true,
      automatic_release: true,
      force: true,
      skip_metadata: false,
      skip_screenshots: false,
      skip_binary_upload: true,
      precheck_include_in_app_purchases: false,
      submission_information: {
        export_compliance_uses_encryption: false,
        content_rights_contains_third_party_content: false,
        add_id_info_uses_idfa: true,
        add_id_info_serves_ads: true,
        add_id_info_tracks_install: false,
        add_id_info_tracks_action: false,
        add_id_info_limits_tracking: true
      }
    )
  end
end
